# Server
PORT=3000
NODE_ENV=development

# MongoDB — start local mongod or use MongoDB Atlas for persistent user accounts
MONGODB_URI=mongodb://localhost:27017/form-builder

# Auth — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=fb_token

# Client-visible origin (CORS + Socket.io)
CLIENT_ORIGIN=http://localhost:3000
